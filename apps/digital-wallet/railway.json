{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/digital-wallet/Dockerfile",
    "watchPatterns": ["apps/digital-wallet/**", "packages/**"]
  },
  "deploy": {
    "startCommand": "sh -c 'HOSTNAME=0.0.0.0 node apps/digital-wallet/server.js'",
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
