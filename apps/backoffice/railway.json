{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/backoffice/Dockerfile",
    "watchPatterns": ["apps/backoffice/**", "packages/**"]
  },
  "deploy": {
    "startCommand": "HOSTNAME=0.0.0.0 node apps/backoffice/server.js",
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
