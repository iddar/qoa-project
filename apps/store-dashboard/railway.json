{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/store-dashboard/Dockerfile",
    "watchPatterns": ["apps/store-dashboard/**", "packages/**"]
  },
  "deploy": {
    "startCommand": "node apps/store-dashboard/server.js",
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
