        "@qoa/auth-client": "workspace:*",
        "@qoa/core": "workspace:*",
        "@qoa/ui": "workspace:*",
        "@tanstack/react-query": "^5",
        "ai": "^6.0.138",
        "html5-qrcode": "^2.3.8",
