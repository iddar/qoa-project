FROM oven/bun:1.3.8-debian AS base

WORKDIR /app

# Install dependencies
COPY src/package.json ./
RUN bun install

# Install pg driver for drizzle-kit migrate
RUN bun add pg

# Copy application code
COPY src/ .

EXPOSE 3000

# Run migrations then start — DATABASE_URL available at runtime via Railway env vars
CMD ["sh", "-c", "bunx drizzle-kit migrate --config drizzle.config.ts && bun index.ts"]
