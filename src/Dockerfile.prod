FROM node:20-alpine

RUN apk add --no-cache curl unzip

RUN curl -fsSL https://github.com/oven/bun/releases/latest/download/bun-linux-x64.zip -o bun.zip && \
    unzip bun.zip && \
    mv bun-linux-x64/bun /usr/local/bin/ && \
    rm -rf bun.zip bun-linux-x64
ENV PATH="/usr/local/bin:$PATH"

WORKDIR /app

COPY package.json ./
COPY bun.lock ./

RUN bun install --frozen-lockfile

COPY . .

RUN bun run db:migrate

EXPOSE 3000

CMD ["bun", "index.js"]
