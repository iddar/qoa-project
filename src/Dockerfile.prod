FROM oven/bun:1.3.8-debian AS base

WORKDIR /app

# Install dependencies
COPY src/package.json ./
RUN bun install

# Install pg driver for drizzle-kit migrate
RUN bun add pg

# Copy application code
COPY src/ .

EXPOSE 3000

# Use the package start script so Railway start-command overrides and Docker CMD behave the same.
CMD ["bun", "run", "start"]
