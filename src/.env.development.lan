# App runtime
QOA_ENV_FILE=src/.env.development.lan
PORT=3000
HOST=0.0.0.0
PUBLIC_HOST=192.168.1.203
NODE_ENV=development
JWT_SECRET=dev-secret
AUTH_ACCESS_TTL_SECONDS=900
AUTH_REFRESH_TTL_DAYS=30
AUTH_DEV_MODE=true

# Postgres (Docker Compose service, exposed to host)
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_DB=qoa_local
POSTGRES_USER=qoa
POSTGRES_PASSWORD=supersecret
DATABASE_URL=postgres://qoa:supersecret@127.0.0.1:5433/qoa_local

# Redis (Docker Compose service, exposed to host)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379/0

# Shared frontend URLs served through Caddy LAN HTTPS
NEXT_PUBLIC_API_URL=https://192.168.1.203:3443
NEXT_PUBLIC_CPG_PORTAL_URL=https://192.168.1.203:3445
NEXT_PUBLIC_STORE_DASHBOARD_URL=https://192.168.1.203:3446
NEXT_PUBLIC_WALLET_URL=https://192.168.1.203:3447
ALLOWED_DEV_ORIGINS=192.168.1.203

# Voice transcription service proxied by Caddy
CHOUGH_URL=https://192.168.1.203:3448
