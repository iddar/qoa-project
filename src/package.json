{
  "name": "@qoa/core",
  "private": true,
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "dev": "bun --env-file=.env.development --hot index.ts",
    "start": "bun index.ts",
    "test": "bun --env-file=.env.test run db:rebuild:test && bun --env-file=.env.test test spec",
    "db:generate": "bunx drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "bunx drizzle-kit migrate --config drizzle.config.ts",
    "db:reset": "bun scripts/db/reset.ts",
    "db:rebuild": "bun run db:reset && bun run db:migrate",
    "db:rebuild:development": "bun --env-file=.env.development run db:rebuild && bun --env-file=.env.development run db:seed:development",
    "db:rebuild:local": "bun --env-file=.env.local run db:rebuild && bun --env-file=.env.local run db:seed:local",
    "db:rebuild:staging": "bun --env-file=.env.staging run db:rebuild && bun --env-file=.env.staging run db:seed:staging",
    "db:rebuild:test": "bun --env-file=.env.test run db:rebuild && bun --env-file=.env.test run db:seed:test",
    "db:studio": "bunx drizzle-kit studio --config drizzle.config.ts",
    "db:seed:development": "bun --env-file=.env.development db/seeds/development.ts",
    "db:seed:local": "bun --env-file=.env.local db/seeds/local.ts",
    "db:seed:staging": "bun --env-file=.env.staging db/seeds/staging.ts",
    "db:seed:test": "bun --env-file=.env.test db/seeds/test.ts",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "tsc --noEmit",
    "lint": "bunx oxlint --type-aware -A all -D typescript/no-floating-promises",
    "lint:fix": "bunx oxlint --fix --type-aware -A all -D typescript/no-floating-promises",
    "bench": "bash bench/run.sh",
    "bench:baseline": "bash bench/run.sh --save-baseline",
    "bench:compare": "bash bench/run.sh --compare"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/jwt": "^1.4.0",
    "@elysiajs/openapi": "^1.4.14",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.22",
    "logestic": "^1.2.4",
    "qrcode": "^1.5.4",
    "twilio": "^6.0.0"
  },
  "devDependencies": {
    "@elysiajs/eden": "^1.4.2",
    "@types/bun": "latest",
    "@types/qrcode": "^1.5.6",
    "@typescript/native-preview": "^7.0.0-dev.20260205.1",
    "drizzle-kit": "^0.31.8",
    "oxfmt": "^0.28.0",
    "oxlint": "^1.43.0",
    "oxlint-tsgolint": "^0.11.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.8"
}
