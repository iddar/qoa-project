{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "src/Dockerfile.prod",
    "watchPatterns": ["src/**"]
  },
  "deploy": {
    "startCommand": "bun index.ts",
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
